<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_qlda_chat_tree" model="ir.ui.view">
        <field name="name">qlda.chat.message.tree</field>
        <field name="model">qlda.chat.message</field>
        <field name="arch" type="xml">
            <tree>
                <field name="content"/>
                <field name="role"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <record id="view_qlda_chat_form" model="ir.ui.view">
        <field name="name">qlda.chat.message.form</field>
        <field name="model">qlda.chat.message</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="role"/>
                        <field name="content"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
