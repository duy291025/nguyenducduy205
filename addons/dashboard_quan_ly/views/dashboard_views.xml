<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =========================
         ACTION DASHBOARD
    ========================== -->
    <record id="action_dashboard_quan_ly" model="ir.actions.act_window">
        <field name="name">Dashboard Tổng Quan</field>
        <field name="res_model">dashboard.quan.ly</field>
        <field name="view_mode">kanban</field>
        <field name="target">current</field>
    </record>

    <!-- =========================
         KANBAN DASHBOARD VIEW
    ========================== -->
    <record id="view_dashboard_quan_ly_kanban" model="ir.ui.view">
        <field name="name">dashboard.quan.ly.kanban</field>
        <field name="model">dashboard.quan.ly</field>
        <field name="arch" type="xml">

            <!-- ❌ KHÔNG js_class -->
            <kanban
                create="false"
                delete="false"
                class="o_kanban_dashboard o_dashboard_fullwidth">

                <!-- ===== FIELDS ===== -->
                <field name="tong_nhan_su"/>
                <field name="tong_du_an"/>
                <field name="tong_cong_viec"/>
                <field name="cong_viec_hoan_thanh"/>

                <templates>
                    <t t-name="kanban-box">

                        <div class="o_kanban_card dashboard-wrapper">

                            <!-- ===== TITLE ===== -->
                            <div class="text-center mb-4">
                                <h2>📊 DASHBOARD TỔNG QUAN</h2>
                            </div>

                            <!-- ===== KPI GRID ===== -->
                            <div class="dashboard-grid mb-5">

                                <button type="object"
                                        name="action_open_nhan_su"
                                        class="dashboard-card bg-info o_dashboard_btn">
                                    <i class="fa fa-users"/>
                                    <div class="value">
                                        <t t-esc="record.tong_nhan_su.value"/>
                                    </div>
                                    <div class="label">Nhân sự</div>
                                </button>

                                <button type="object"
                                        name="action_open_du_an"
                                        class="dashboard-card bg-primary o_dashboard_btn">
                                    <i class="fa fa-folder-open"/>
                                    <div class="value">
                                        <t t-esc="record.tong_du_an.value"/>
                                    </div>
                                    <div class="label">Dự án</div>
                                </button>

                                <button type="object"
                                        name="action_open_cong_viec"
                                        class="dashboard-card bg-warning o_dashboard_btn">
                                    <i class="fa fa-tasks"/>
                                    <div class="value">
                                        <t t-esc="record.tong_cong_viec.value"/>
                                    </div>
                                    <div class="label">Công việc</div>
                                </button>

                                <button type="object"
                                        name="action_open_cong_viec_hoan_thanh"
                                        class="dashboard-card bg-success o_dashboard_btn">
                                    <i class="fa fa-check-circle"/>
                                    <div class="value">
                                        <t t-esc="record.cong_viec_hoan_thanh.value"/>
                                    </div>
                                    <div class="label">Hoàn thành</div>
                                </button>

                            </div>

                            <!-- ===== CHART ===== -->
                            <div class="card p-4 shadow-sm">
                                <h4 class="mb-3">📈 Biểu đồ thống kê</h4>

                                <div class="o_dashboard_chart"
                                     t-att-data-nhan-su="record.tong_nhan_su.value"
                                     t-att-data-du-an="record.tong_du_an.value"
                                     t-att-data-cong-viec="record.tong_cong_viec.value"
                                     t-att-data-hoan-thanh="record.cong_viec_hoan_thanh.value">

                                    <canvas id="dashboard_bar_chart" height="120"/>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>

            </kanban>
        </field>
    </record>

</odoo>
