<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="action_dashboard_quan_ly" model="ir.actions.act_window">
            <field name="name">Dashboard Tổng Quan</field>
            <field name="res_model">dashboard.quan.ly</field>
            <field name="view_mode">kanban</field>
            <field name="target">current</field>
        </record>

        <record id="view_dashboard_quan_ly_kanban" model="ir.ui.view">
            <field name="name">dashboard.quan.ly.kanban</field>
            <field name="model">dashboard.quan.ly</field>
            <field name="arch" type="xml">
                <kanban create="false" delete="false" class="o_kanban_dashboard">
                    <field name="tong_nhan_su"/>
                    <field name="tong_du_an"/>
                    <field name="tong_cong_viec"/>
                    <field name="cong_viec_hoan_thanh"/>

                    <templates>
                        <t t-name="kanban-box">
                            <div class="o_kanban_card o_kanban_global_click" 
                                 style="width: 100% !important; max-width: 100% !important; flex: 1 1 100% !important; border: none; background: #f8f9fa; margin: 0; padding: 20px;">
                                
                                <div class="text-center mb-4">
                                    <h2 style="font-weight: bold; color: #2c3e50;">📊 DASHBOARD TỔNG QUAN</h2>
                                </div>

                                <div style="display: flex; justify-content: space-between; gap: 20px; margin-bottom: 30px;">
                                    <div class="bg-info" style="flex: 1; padding: 25px; border-radius: 10px; text-align: center; color: white;">
                                        <i class="fa fa-users fa-3x mb-2"/>
                                        <div style="font-size: 32px; font-weight: bold;"><t t-esc="record.tong_nhan_su.raw_value"/></div>
                                        <div>Nhân sự</div>
                                    </div>

                                    <div class="bg-primary" style="flex: 1; padding: 25px; border-radius: 10px; text-align: center; color: white;">
                                        <i class="fa fa-folder-open fa-3x mb-2"/>
                                        <div style="font-size: 32px; font-weight: bold;"><t t-esc="record.tong_du_an.raw_value"/></div>
                                        <div>Dự án</div>
                                    </div>

                                    <div class="bg-warning" style="flex: 1; padding: 25px; border-radius: 10px; text-align: center; color: white;">
                                        <i class="fa fa-tasks fa-3x mb-2"/>
                                        <div style="font-size: 32px; font-weight: bold;"><t t-esc="record.tong_cong_viec.raw_value"/></div>
                                        <div>Công việc</div>
                                    </div>

                                    <div class="bg-success" style="flex: 1; padding: 25px; border-radius: 10px; text-align: center; color: white;">
                                        <i class="fa fa-check-circle fa-3x mb-2"/>
                                        <div style="font-size: 32px; font-weight: bold;"><t t-esc="record.cong_viec_hoan_thanh.raw_value"/></div>
                                        <div>Hoàn thành</div>
                                    </div>
                                </div>

                                <div class="card p-4 shadow-sm" style="background: white; border-radius: 15px; border: 1px solid #dee2e6;">
                                    <h4 class="mb-3" style="border-left: 5px solid #007bff; padding-left: 15px;">📈 Biểu đồ thống kê</h4>
                                    
                                    <div class="o_dashboard_chart"
                                         t-att-data-nhan-su="record.tong_nhan_su.raw_value"
                                         t-att-data-du-an="record.tong_du_an.raw_value"
                                         t-att-data-cong-viec="record.tong_cong_viec.raw_value"
                                         t-att-data-hoan-thanh="record.cong_viec_hoan_thanh.raw_value">
                                        <canvas id="dashboard_bar_chart" style="max-height: 300px; width: 100%;"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
    </data>
</odoo>