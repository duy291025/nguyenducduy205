<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================= FORM VIEW ================= -->
        <record id="view_quan_ly_du_an_form" model="ir.ui.view">
            <field name="name">quan_ly_du_an.form</field>
            <field name="model">quan_ly_du_an</field>
            <field name="arch" type="xml">
                <form string="Quản Lý Dự Án">
                    <sheet>

                        <!-- THÔNG TIN DỰ ÁN -->
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="status"/>
                        </group>

                        <!-- THÀNH VIÊN DỰ ÁN -->
                        <group string="Thành viên dự án">
                            <!-- ✅ HIỆN TẤT CẢ NHÂN SỰ -->
                            <field name="thanh_vien_ids" widget="many2many_tags"/>
                        </group>

                        <!-- CÔNG VIỆC -->
                        <group string="Công việc">
                            <field name="cong_viec_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="assigned_to"/>
                                    <field name="deadline"/>
                                    <field name="priority"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- ================= TREE VIEW ================= -->
        <record id="view_quan_ly_du_an_tree" model="ir.ui.view">
            <field name="name">quan_ly_du_an.tree</field>
            <field name="model">quan_ly_du_an</field>
            <field name="arch" type="xml">
                <tree string="Danh sách dự án">
                    <field name="name"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="status"/>
                </tree>
            </field>
        </record>

        <!-- ================= ACTION ================= -->
        <record id="action_quan_ly_du_an" model="ir.actions.act_window">
            <field name="name">Quản Lý Dự Án</field>
            <field name="res_model">quan_ly_du_an</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
