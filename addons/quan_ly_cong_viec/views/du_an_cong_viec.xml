<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================= FORM VIEW ================= -->
        <record id="view_du_an_cong_viec_form" model="ir.ui.view">
            <field name="name">du_an_cong_viec.form</field>
            <field name="model">du_an_cong_viec</field>
            <field name="arch" type="xml">
                <form string="Công Việc Dự Án">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>

                            <!-- ✅ KHÔNG CẦN FIELD KỸ THUẬT -->

                            <field name="assigned_to"/>
                            <field name="deadline"/>
                            <field name="priority"/>
                            <field name="status"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ================= TREE VIEW ================= -->
        <record id="view_du_an_cong_viec_tree" model="ir.ui.view">
            <field name="name">du_an_cong_viec.tree</field>
            <field name="model">du_an_cong_viec</field>
            <field name="arch" type="xml">
                <tree string="Danh sách công việc">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="assigned_to"/>
                    <field name="deadline"/>
                    <field name="priority"/>
                    <field name="status"/>
                </tree>
            </field>
        </record>

        <!-- ================= SEARCH VIEW ================= -->
        <record id="view_du_an_cong_viec_search" model="ir.ui.view">
            <field name="name">du_an_cong_viec.search</field>
            <field name="model">du_an_cong_viec</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm công việc">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="status"/>

                    <!-- 🔥 FILTER: CÔNG VIỆC CỦA TÔI -->
                    <filter
                        string="Công việc của tôi"
                        name="my_tasks"
                        domain="[('assigned_to.user_id', '=', uid)]"
                    />
                </search>
            </field>
        </record>

        <!-- ================= ACTION ================= -->
        <record id="action_du_an_cong_viec" model="ir.actions.act_window">
            <field name="name">Quản Lý Công Việc</field>
            <field name="res_model">du_an_cong_viec</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_du_an_cong_viec_search"/>
        </record>

    </data>
</odoo>
